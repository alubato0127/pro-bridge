# Copy to .env and edit.

# CDP endpoint of the debug Chrome (local to this laptop; not exposed).
PRO_BRIDGE_CDP_URL=http://localhost:9222

# Bind so the remote Claude Code can reach it over Tailscale.
# 0.0.0.0 works; or pin to your tailnet IP from `tailscale ip -4`.
PRO_BRIDGE_HOST=0.0.0.0
PRO_BRIDGE_PORT=8765

# Shared secret. Callers must send: Authorization: Bearer <this value>.
# Generate one, e.g. python -c "import secrets;print(secrets.token_urlsafe(32))"
PRO_BRIDGE_TOKEN=change-me-to-a-long-random-string

# Optional: force a Pro model slug on NEW chats (e.g. gpt-5-pro, o1-pro).
# Leave empty to use whatever model the bridge Chrome currently has selected.
# Find the real slug by running: python selftest.py  (it logs the model).
GPT_PRO_MODEL_SLUG=

# Refuse to return an answer if the active model isn't a Pro model.
PRO_BRIDGE_STRICT_MODEL=1

# Max seconds to wait for one Pro answer (Pro reasons for minutes).
PRO_BRIDGE_TIMEOUT=1800
